# ─── Copy to .env in the project root for docker-compose ─────────────────────

# Required
JWT_SECRET=change_me_in_production_32_chars_minimum
COOKIE_SECRET=another_strong_random_secret_here

# Optional — defaults shown
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost

# Razorpay (leave blank to use demo/fallback mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
