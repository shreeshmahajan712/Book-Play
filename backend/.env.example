# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/turfReserve
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.mongodb.net/turfReserve
MONGO_URI=mongodb://127.0.0.1:27017/turfReserve

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE_MS=604800000

# ─── Redis (optional — leave empty to use in-memory cache) ─────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ─── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Commission Rate ───────────────────────────────────────────────────────────
COMMISSION_RATE=0.10
